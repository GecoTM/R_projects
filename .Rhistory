range(boston$rm)
mean(boston$rm)
corrplot(cor(boston), method = "square")
install.packages("psych")
library(MASS)
library(ISLR2)
library(ggplot2)
library(reshape2)
library(corrplot)
library(psych)
boston <- read.csv("Boston.csv")
head(boston)
summary(boston)
psych::describe(boston)
modello1 <- lm(medv ~ rm, data = boston)
summary(modello1)
range(boston$rm)
mean(boston$rm)
corrplot(cor(boston), method = "square")
ggplot(boston, aes(x = rm, y = medv,)) +
geom_point() +
labs(x = "Stanze",
y = "Prezzo Mediano") +
geom_smooth(method=lm, se=FALSE) +
theme_minimal()
d_scatola <- ggplot(boston, aes(medv)) +
geom_boxplot() +
theme_minimal()
print(d_scatola)
confint(modello1)
predict(modello1, data.frame(rm = (6)),
interval = "confidence")
predict(modello1, data.frame(rm = (6)),
interval = "prediction")
modello2 <- lm(medv ~ rm + lstat, data = boston)
summary(modello2)
library(MASS)
library(ISLR2)
library(ggplot2)
library(reshape2)
library(corrplot)
library(psych)
boston <- read.csv("Boston.csv")
head(boston)
summary(boston)
psych::describe(boston)
modello1 <- lm(medv ~ rm, data = boston)
summary(modello1)
range(boston$rm)
mean(boston$rm)
corrplot(cor(boston), method = "square")
ggplot(boston, aes(x = rm, y = medv,)) +
geom_point() +
labs(x = "Stanze",
y = "Prezzo Mediano") +
geom_smooth(method=lm, se=FALSE) +
theme_minimal()
d_scatola <- ggplot(boston, aes(medv)) +
geom_boxplot() +
theme_minimal()
print(d_scatola)
confint(modello1)
predict(modello1, data.frame(rm = (6)),
interval = "confidence")
predict(modello1, data.frame(rm = (6)),
interval = "prediction")
modello2 <- lm(medv ~ rm + lstat, data = boston)
summary(modello2)
mean(boston$lstat)
predict(modello2, data.frame(rm = (6), lstat = (12)),
interval = "confidence")
predict(modello2, data.frame(rm = (6), lstat = (12)),
interval = "prediction")
plot(predict(modello2), residuals(modello2))
